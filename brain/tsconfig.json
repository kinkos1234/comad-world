{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "types": ["bun-types"],
    "paths": {
      "@comad-brain/core": ["./packages/core/src/index.ts"],
      "@comad-brain/graphrag": ["./packages/graphrag/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts"]
}
